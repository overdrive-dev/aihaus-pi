{
  "name": "aihaus-pi",
  "version": "0.2.0",
  "description": "Business-rule-first autonomous development harness for Pi.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overdrive-dev/aihaus-pi.git"
  },
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "aihaus",
    "agent",
    "workflow",
