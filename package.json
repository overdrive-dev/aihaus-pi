    "src",
    "skills",
    "prompts",
    "templates",
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/check.mjs",
    "check": "node scripts/check.mjs",
    "test": "node --test tests/*.test.mjs",
    "smoke": "npm run check && npm test"
  },
  "bin": {
    "aihaus": "bin/aihaus.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4"
